# Pickman's Whisper — machine-specific dev settings (build/deploy tooling only).
#
# Copy this file to ".env" (same folder) and set the paths for YOUR machine.
# ".env" is git-ignored, so nothing here is hardcoded into the repo or the mod.
# Real environment variables, if set, take precedence over values in .env.
#
# None of this is packaged into the mod — the shipped .pex/.esp/config use only
# game-relative paths (Data\PickmansWhisper\config\...).

# Full path to your Fallout4.esm (used by the ESP builder + blade-detect test).
FALLOUT4_ESM=C:\Program Files (x86)\Steam\steamapps\common\Fallout 4\Data\Fallout4.esm

# Your MO2 (or manual) mod folder to deploy into. Should end in \PickmansWhisper.
PICKMANS_WHISPER_DEPLOY=C:\path\to\MO2\mods\PickmansWhisper

# Optional: ROF DeadOverlays overlays.json (Slice H contract — template id check).
# ROF_DEAD_OVERLAYS_JSON=C:\path\to\MO2\mods\Random Overlay Framework\F4SE\Plugins\F4EE\Overlays\INVB_OverlayFramework_DeadOverlays.esp\overlays.json

# Optional: Porcupine Skin Overlays overlays.json (Slice H P0.2 contract).
# PORC_OVERLAYS_JSON=C:\path\to\MO2\mods\PorcOverlays_esl_\F4SE\Plugins\F4EE\Overlays\Porcoverlays.esl\overlays.json

# Optional: Scripted Face Tints SFT.esp (Wound Lab face / Boxer Damage FULL-name check).
# SFT_ESP=C:\path\to\MO2\mods\SFT\SFT.esp

# Optional: override repo root or Caprica location (defaults are usually fine).
# PICKMANS_WHISPER_ROOT=
# CAPRICA=
