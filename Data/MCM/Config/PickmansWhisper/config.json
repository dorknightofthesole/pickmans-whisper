						"sourceType": "ModSettingBool"
					}
				},
				{
					"id": "iNoticeStage:Debug",
					"text": "Notice stage",
					"type": "menu",
					"help": "Current whisper escalation stage. When 'Force notice stage' is off this tracks hunger (updates on Refresh). When on, this pins the stage so you can test each one without grinding hunger.",
