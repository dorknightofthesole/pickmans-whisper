					"type": "text",
					"html": true
				}
			]
		},
		{
			"pageDisplayName": "Victims",
			"content": [
				{
					"text": "!!! MCM PING (MessageBox) !!!",
					"type": "button",
					"help": "CallGlobalFunction Debug.MessageBox — proves MCM buttons work even if quest CallFunction is broken.",
					"action": {
						"type": "CallGlobalFunction",
						"script": "Debug",
						"function": "MessageBox",
						"params": [
							"Pickman's Whisper MCM PING\n\nIf you see this, MCM buttons work.\nNext: try Refresh aimed / list."
						]
					}
				},
				{
					"text": "Look at someone, type a name, then <b>Name aimed NPC</b>. That becomes her world/HUD name and fills {name} in whispers. Generics (Settler, Resident) are rejected.",
					"type": "text",
					"html": true
				},
				{
					"id": "sVictimAimed:Victims",
					"text": "Aimed now",
					"type": "textinput",
					"help": "Face someone in-world for ~2s (killscan caches them), then open this page. Refresh does not re-scan the world — it only re-pushes the cache.",
					"valueOptions": {
						"sourceType": "ModSettingString"
					}
				},
				{
					"id": "sDecayStage:Victims",
					"text": "Decay stage",
					"type": "textinput",
					"help": "Decay for the cached body. Named victims without a clock start Freshly Deceased (overlays apply after you close MCM). Blade kills stamp automatically.",
					"valueOptions": {
						"sourceType": "ModSettingString"
					}
				},
				{
					"id": "sVictimName:Victims",
					"text": "New name",
					"type": "textinput",
					"help": "Real name only (e.g. Marie). Not Settler/Resident.",
					"valueOptions": {
						"sourceType": "ModSettingString"
					}
				},
				{
					"text": "Name aimed NPC",
					"type": "button",
					"help": "SetDisplayName on the aimed / last-look actor + save FormID↔name for whispers.",
					"action": {
						"type": "CallFunction",
						"form": "PickmansWhisper.esp|800",
						"function": "MCMNameAimedVictim",
						"scriptName": "PickmansWhisperMainQuestScript"
					}
				},
				{
					"text": "Refresh aimed / list",
					"type": "button",
					"help": "Re-push Aimed / Decay / named list from cache. Opens a MessageBox so you can confirm the button fired. Face the body in-world before opening MCM.",
					"action": {
						"type": "CallFunction",
						"form": "PickmansWhisper.esp|800",
						"function": "MCMRefreshVictimsPanel",
						"scriptName": "PickmansWhisperMainQuestScript"
					}
				},
				{
					"type": "spacer",
					"numLines": 1
				},
				{
					"id": "sVictimStatus:Victims",
					"text": "Last apply",
