				{
					"text": "Delivery",
					"type": "section"
				},
				{
					"id": "iVoiceDelivery:Voice",
					"text": "Voice delivery",
					"type": "stepper",
					"help": "How notices are delivered. Toast and Audio (default): HUD toast and matching whisper clip. Audio only: clip with no toast. Toast only: toast with no audio.",
					"valueOptions": {
						"sourceType": "ModSettingInt",
						"options": [
							"Toast and Audio",
							"Audio only",
							"Toast only"
						]
					}
				},
				{
					"id": "bBedGift:Voice",
					"text": "Bed gift hallucination",
					"type": "switcher",
					"help": "While bonded, occasionally spawn an ephemeral corpse in your bed on sleep. Look away after seeing her and she vanishes. Pure vignette — no hunger change.",
					"valueOptions": {
						"sourceType": "ModSettingBool"
					}
				},
