				{
					"text": "Reload line banks",
					"type": "button",
					"help": "Re-reads the five NoticeLines_*.txt files from disk (no game restart) and reports each file's load status.",
					"action": {
						"type": "CallFunction",
						"form": "PickmansWhisper.esp|800",
						"function": "DebugReloadLines"
					}
				},
				{
					"text": "Notice whispers are editable under Data/PickmansWhisper/config/ (NoticeLines_Calm/Restless/Hungry/Starving/Desperate.txt). Trust/hunger/praise are builtin. See the Debug page for per-file load status.",
					"type": "text",
					"html": true
				}
			]
		},
		{
			"pageDisplayName": "Debug",
			"content": [
				{
					"id": "bKillDebugToasts:Debug",
					"text": "Kill / scan debug toasts",
					"type": "switcher",
					"help": "Blade status, scan heartbeats, HUMAN kill / ignore reasons. Off by default. Praise and hunger voice are separate (Voice page).",
					"valueOptions": {
						"sourceType": "ModSettingBool"
					}
				},
				{
					"id": "bNoticePollDebug:Debug",
					"text": "Notice poll dialogs",
					"type": "switcher",
					"help": "Auto MessageBox every ~8s while notice polling: who was nearby and why each failed or passed. No button needed. Turn off when done debugging.",
