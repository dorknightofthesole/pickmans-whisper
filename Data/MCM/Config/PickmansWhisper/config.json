					"text": "Addicted threshold",
					"type": "slider",
					"valueOptions": {
						"min": 25,
						"max": 100,
						"step": 5,
						"sourceType": "ModSettingFloat"
					}
				},
				{
					"id": "fSatedHours:Hunger",
					"text": "Sated duration (game hours)",
					"type": "slider",
					"help": "After satiation (Slice B knife kill / debug button).",
					"valueOptions": {
						"min": 0.5,
						"max": 48,
						"step": 0.5,
						"sourceType": "ModSettingFloat"
					}
				}
			]
