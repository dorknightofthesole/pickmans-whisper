				{
					"text": "Reload line banks",
					"type": "button",
					"help": "Re-reads NoticeLines_*.txt and *_Audio.txt from disk (no game restart) and reports load status.",
					"action": {
						"type": "CallFunction",
						"form": "PickmansWhisper.esp|800",
						"function": "DebugReloadLines",
						"scriptName": "PickmansWhisperMainQuestScript"
