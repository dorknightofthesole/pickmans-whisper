						"function": "DebugTestTrustLine"
					}
				},
				{
					"text": "Test notice (nearby woman)",
					"type": "button",
					"help": "Comments on the nearest non-hostile adult female in range (C2).",
					"action": {
						"type": "CallFunction",
						"form": "PickmansWhisper.esp|800",
						"function": "DebugTestNoticeLine"
